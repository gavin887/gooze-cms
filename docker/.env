# ========================================
# Gooze-CMS Docker 环境变量配置示例
# ========================================
# 复制此文件为 .env 并根据实际情况修改

# ========================================
# MySQL 数据库配置
# ========================================
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=gooze-admin
MYSQL_USER=gooze-admin
MYSQL_PASSWORD=gooze-admin

# ========================================
# Redis 配置
# ========================================
REDIS_PORT=6379
REDIS_PASSWORD=

# ========================================
# 后端服务配置
# ========================================
BACKEND_PORT=18002

# 应用基本配置
APP_NAME=gooze-admin
APP_ENV=production
APP_ADDR=:18002
APP_TIMEOUT=1
APP_ROUTER_PREFIX=/api/v1

# 数据库连接配置
DB_DRIVER=mysql
DB_DSN=gooze-admin:gooze-admin@tcp(mysql:3306)/gooze-admin?charset=utf8mb4&parseTime=True&loc=Local&timeout=5s
DB_MAX_IDLE_CONN=10
DB_MAX_CONN=200
DB_LOG_LEVEL=3

# Redis 连接配置
REDIS_ADDR=redis:6379
REDIS_DB=0

# JWT 配置
JWT_SECRET_KEY=123456
JWT_EXPIRE=86400

# OSS 对象存储配置
OSS_TYPE=local
OSS_URL=http://localhost:18002
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET_NAME=

# 日志配置
LOG_PATH=./logs/
LOG_MODE=both

# ========================================
# 前端服务配置
# ========================================
FRONTEND_PORT=8080

# API 地址（前端调用的 API 路径）
# 相对路径时通过 nginx 代理，绝对路径时直接请求
API_URL=/api/v1

# API 后端基础地址（nginx 代理的目标地址）
API_BASE_URL=http://backend:18002
